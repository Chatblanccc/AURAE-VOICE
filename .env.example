# Copy this file to .env.local and fill in your actual values
# cp .env.example .env.local

# Auth.js / NextAuth — required in production (`npx auth secret` to generate)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

KIMI_API_KEY=your_moonshot_api_key_here
KIMI_API_URL=https://api.moonshot.cn/v1

# Neon Postgres (serverless). Use a secret connection string; never commit real credentials.
DATABASE_URL=

# Optional. ONLY for controlled single-tenant migration of legacy UUID user_ids. Do not set in multi-tenant production.
# LEGACY_UUID_MIGRATION_ENABLED=true

# Fish Audio TTS — get your key at https://fish.audio/app/api-keys/
# Used for high-quality voice synthesis (e.g. Trump voice)
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys (use test keys during dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create two Products + recurring Prices in the Stripe Dashboard, then paste the
# Price IDs here (e.g. price_1AbcDef...).  mode: subscription, billing: monthly.
STRIPE_PLUS_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Public key — safe to expose in browser (used for future Stripe.js if needed)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Alipay (optional)
# - Turn on Alipay under https://dashboard.stripe.com/settings/payment_methods
# - Important: Stripe Checkout in **subscription** mode does NOT support Alipay (same as WeChat Pay).
#   Docs: https://docs.stripe.com/payments/alipay (see Checkout footnote + “Recurring payments”).
# - Recurring Alipay on Stripe may be available only by application / invite — contact Stripe Support if you need it.
# This app’s subscription flow uses `/api/stripe/checkout` (mode: subscription); customers typically pay by card.
