# Copy this file to .env.local and fill in your actual values
# cp .env.example .env.local

# Auth.js / NextAuth — required in production (`npx auth secret` to generate)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

KIMI_API_KEY=your_moonshot_api_key_here
KIMI_API_URL=https://api.moonshot.cn/v1

# Neon Postgres (serverless). Use a secret connection string; never commit real credentials.
DATABASE_URL=

# Optional. ONLY for controlled single-tenant migration of legacy UUID user_ids. Do not set in multi-tenant production.
# LEGACY_UUID_MIGRATION_ENABLED=true

# Fish Audio TTS — get your key at https://fish.audio/app/api-keys/
# Used for high-quality voice synthesis (e.g. Trump voice)
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here
